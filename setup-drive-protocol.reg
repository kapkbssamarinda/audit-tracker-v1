Windows Registry Editor Version 5.00

[HKEY_CLASSES_ROOT\gdrive]
@="URL:KAP KBS Google Drive Protocol"
"URL Protocol"=""

[HKEY_CLASSES_ROOT\gdrive\shell]

[HKEY_CLASSES_ROOT\gdrive\shell\open]

[HKEY_CLASSES_ROOT\gdrive\shell\open\command]
@="powershell.exe -WindowStyle Hidden -ExecutionPolicy Bypass -File \"C:\\Tools\\GdriveHandler\\gdrive_handler.ps1\" \"%1\""
